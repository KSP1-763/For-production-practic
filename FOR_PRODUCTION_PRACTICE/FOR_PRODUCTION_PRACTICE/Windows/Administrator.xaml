<Window x:Class="FOR_PRODUCTION_PRACTICE.Windows.Administrator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FOR_PRODUCTION_PRACTICE.Windows"
        mc:Ignorable="d"
        Title="Administrator" Height="450" Width="800">
    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <TextBlock Text=" Администратор" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <Button Content="Выйти" HorizontalAlignment="Right" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="10,5" Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Пользователи">
                <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleRussian}"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Статистика">
                <StackPanel Margin="10">
                    <TextBlock x:Name="TotalUsers" FontSize="16" Margin="0,10"/>
                    <TextBlock x:Name="TotalRequests" FontSize="16" Margin="0,10"/>
                    <TextBlock x:Name="TotalEquipment" FontSize="16" Margin="0,10"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
