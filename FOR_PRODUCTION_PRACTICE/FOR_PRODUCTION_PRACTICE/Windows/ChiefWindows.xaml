<Window x:Class="FOR_PRODUCTION_PRACTICE.Windows.ChiefWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FOR_PRODUCTION_PRACTICE.Windows"
        mc:Ignorable="d"
        Title="ChiefWindows" Height="450" Width="800">
    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#E67E22" Padding="10">
            <Grid>
                <TextBlock x:Name="TitleText" Text=" Начальник подразделения" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <Button Content="Выйти" HorizontalAlignment="Right" Background="#E74C3C" Foreground="White" BorderThickness="0" Padding="10,5" Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <!-- Содержимое -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" Margin="0,0,0,10">
                <TabItem Header="📋 Заявки">
                    <DataGrid x:Name="RequestsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id_request}" Width="50"/>
                            <DataGridTextColumn Header="Номер" Binding="{Binding RequestNumber}" Width="120"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateReceived, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Оборудование" Binding="{Binding EquipmentType}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Заявитель" Binding="{Binding RequesterName}" Width="120"/>
                            <DataGridTextColumn Header="Инженер" Binding="{Binding EngineerName}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="👥 Сотрудники">
                    <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding position}" Width="150"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleRussian}" Width="100"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="📊 Статистика">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="TotalRequests" FontSize="16" Margin="0,5"/>
                        <TextBlock x:Name="NewRequests" FontSize="16" Margin="0,5" Foreground="#E74C3C"/>
                        <TextBlock x:Name="CompletedRequests" FontSize="16" Margin="0,5" Foreground="#27AE60"/>
                        <TextBlock x:Name="TotalUsers" FontSize="16" Margin="0,5"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
