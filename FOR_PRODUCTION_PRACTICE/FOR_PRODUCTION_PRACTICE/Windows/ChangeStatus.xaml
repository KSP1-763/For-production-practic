<Window x:Class="FOR_PRODUCTION_PRACTICE.Windows.ChangeStatus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FOR_PRODUCTION_PRACTICE.Windows"
        mc:Ignorable="d"
        Title="ChangeStatus" Height="300" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Изменение статуса заявки" 
                   FontSize="16" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Заявка:" FontSize="14" FontWeight="Bold"/>
            <TextBlock x:Name="RequestNumberText" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Новый статус:" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="StatusComboBox" FontSize="14" Padding="5">
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="Принята"/>
                <ComboBoxItem Content="В работе"/>
                <ComboBoxItem Content="Ожидание запчастей"/>
                <ComboBoxItem Content="Выполнена"/>
                <ComboBoxItem Content="Отклонена"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Background="#27AE60" 
                    Foreground="White"
                    BorderThickness="0"
                    Padding="30,12"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="SaveButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Отмена" 
                    Background="#DC143C" 
                    Foreground="White"
                    BorderThickness="0"
                    Padding="30,12"
                    Cursor="Hand"
                    Click="CancelButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
