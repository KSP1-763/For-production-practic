<Window x:Class="FOR_PRODUCTION_PRACTICE.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FOR_PRODUCTION_PRACTICE.Windows"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="747" Width="450" WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F2F5" Margin="0,0,0,-6" >
        <Border Margin="20,20,20,10" CornerRadius="10" Background="White" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Регистрация нового пользователя" 
                           FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Фамилия -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Фамилия:" FontWeight="SemiBold"/>
                    <TextBox x:Name="LastNameBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Имя -->
                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="Имя:" FontWeight="SemiBold"/>
                    <TextBox x:Name="FirstNameBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Отчество -->
                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <TextBlock Text="Отчество:" FontWeight="SemiBold"/>
                    <TextBox x:Name="MiddleNameBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Должность -->
                <StackPanel Grid.Row="4" Margin="0,0,0,10">
                    <TextBlock Text="Должность:" FontWeight="SemiBold"/>
                    <TextBox x:Name="PositionBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Телефон -->
                <StackPanel Grid.Row="5" Margin="0,0,0,10">
                    <TextBlock Text="Номер телефона:" FontWeight="SemiBold"/>
                    <TextBox x:Name="PhoneBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Row="6" Margin="0,0,0,10">
                    <TextBlock Text="Email:" FontWeight="SemiBold"/>
                    <TextBox x:Name="EmailBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Логин -->
                <StackPanel Grid.Row="7" Margin="0,0,0,10">
                    <TextBlock Text="Логин:" FontWeight="SemiBold"/>
                    <TextBox x:Name="LoginBox" Padding="8" Margin="0,5,0,0"/>
                </StackPanel>

                
                <StackPanel Grid.Row="8" Margin="0,0,0,10">
                    <TextBlock Text="Пароль:" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="PasswordBox" Padding="8" Margin="0,5,0,0"/>
                    <CheckBox x:Name="ShowPasswordCheck" Content="Показать пароль" Margin="0,5,0,0" Checked="ShowPassword_Checked" Unchecked="ShowPassword_Unchecked"/>
                    <TextBox x:Name="VisiblePasswordBox" Padding="8" Margin="0,5,0,0" Visibility="Collapsed"/>
                </StackPanel>

              
                <StackPanel Grid.Row="9" Margin="0,0,0,10" Visibility="Collapsed">
                    <TextBlock Text="Роль:" FontWeight="SemiBold"/>
                    <ComboBox x:Name="RoleCombo" Padding="8" Margin="0,5,0,0">
                        <ComboBoxItem Content="Сотрудник" Tag="User" IsSelected="True"/>
                        <ComboBoxItem Content="Инженер" Tag="Engineer"/>
                        <ComboBoxItem Content="Начальник" Tag="Chief"/>
                    </ComboBox>
                </StackPanel>

               
                <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Зарегистрировать" Background="#27AE60"  
                            BorderThickness="0" Padding="25,10" Cursor="Hand" Click="Register_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Отмена" Background="#DC143C" 
                            BorderThickness="0" Padding="25,10" Margin="10,0,0,0" Cursor="Hand" Click="Cancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

              
                <TextBlock x:Name="StatusText" Grid.Row="11" Text="" HorizontalAlignment="Center" 
                           Margin="0,10,0,0" Foreground="Red" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
